# Auth
NEXTAUTH_SECRET=replace-with-secure-random-string
AUTH_URL=https://your-domain.example
HMAC_SECRET_KEY=replace-with-secure-random-string

# World mini app
NEXT_PUBLIC_APP_ID=app_your_app_id
APP_ID=app_your_app_id
DEV_PORTAL_API_KEY=your_dev_portal_key
NEXT_PUBLIC_WORLD_ID_APP_ID=app_your_app_id
WORLD_ID_APP_ID=app_your_app_id
WORLD_ID_RP_ID=rp_your_rp_id
WORLD_ID_RP_PRIVATE_KEY=0xyour_signing_key
WORLD_ID_ACTION=valor-contribution
WORLD_ID_ENVIRONMENT=production

# Maps
NEXT_PUBLIC_MAP_PROVIDER=apple
APPLE_MAPS_TEAM_ID=your_team_id
APPLE_MAPS_KEY_ID=your_key_id
APPLE_MAPS_MAPS_ID=your_maps_id
APPLE_MAPS_PRIVATE_KEY=\"-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\"

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Rewards contract
REWARD_CONTRACT_ADDRESS=0x...
REWARD_SIGNER_PRIVATE_KEY=0x...
PRIVATE_KEY=0x...
WORLD_CHAIN_RPC_URL=https://worldchain-mainnet.g.alchemy.com/v2/your_key

# Cron auth
CRON_SECRET=replace-with-secure-random-string

# Optional dev-only wallet bypass (never enable in production)
ENABLE_DEV_AUTH=false
NEXT_PUBLIC_ENABLE_DEV_AUTH=false
NEXT_PUBLIC_WORLD_DEV_BYPASS=false
