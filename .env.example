# NextAuth Configuration
NEXTAUTH_SECRET=your_random_secret_here
HMAC_SECRET_KEY=your_random_hmac_secret_here

# Auth URL (must be HTTPS for World App - use ngrok for development)
AUTH_URL=http://localhost:3000

# World ID Application ID (get from https://developer.worldcoin.org)
NEXT_PUBLIC_APP_ID=your_worldcoin_app_id

# Google Maps API Key (get from https://console.cloud.google.com)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Supabase Configuration (get from https://supabase.com)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
