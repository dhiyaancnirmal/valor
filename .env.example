# NextAuth Configuration
NEXTAUTH_SECRET=your-nextauth-secret-here
HMAC_SECRET_KEY=your-hmac-secret-key-here

# Auth URL (must be HTTPS for World App - use ngrok for development)
AUTH_URL=http://localhost:3000

# World ID Application ID (get from https://developer.worldcoin.org)
NEXT_PUBLIC_APP_ID=app_your_app_id_here

# Google Maps API Key (get from https://console.cloud.google.com)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Supabase Configuration (get from https://supabase.com)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# World Chain RPC URL
WORLDCHAIN_RPC=https://worldchain-mainnet.g.alchemy.com/v2/your_alchemy_key_here

# Deployer/Owner Private Key (for deploying contracts and calling batchPayout)
PRIVATE_KEY=0x_your_deployer_private_key_here

# World ID Configuration
APP_ID=app_your_app_id_here
DEV_PORTAL_API_KEY=your_dev_portal_api_key_here

# Reward Contract Configuration
REWARD_CONTRACT_ADDRESS=0x_your_reward_contract_address_here
REWARD_SIGNER_PRIVATE_KEY=0x_your_signer_private_key_here
NEXT_PUBLIC_REWARD_CONTRACT_ADDRESS=0x_your_reward_contract_address_here

# Reward Amount (in smallest USDC units - 6 decimals)
REWARD_AMOUNT_USDC=500000        # 0.5 USDC in 6 decimals
DAILY_REWARD_BUDGET_USD=20       # your daily cap

# Cron secret for payout API authentication
CRON_SECRET=your-random-secret-here
